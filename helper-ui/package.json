{
  "name": "@ava/helper-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AVA Helper — Electron tray-app med inbyggd in-process helper-motor (ADR 0029/0030).",
  "main": "dist/main.cjs",
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "icons": "bun make-icons.ts",
    "bundle": "bun build src/main.ts --target=node --format=cjs --external electron --outfile=dist/main.cjs",
    "dev": "bun run bundle && electron dist/main.cjs",
    "dist": "bun run icons && bun run bundle && electron-builder"
  },
  "devDependencies": {
    "@trpc/server": "^11.17.0",
    "@types/node-forge": "^1.3.14",
    "bun-types": "^1.3.14",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@trpc/client": "^11.17.0",
    "node-forge": "^1.4.0",
    "superjson": "^2.2.6"
  },
  "build": {
    "appId": "se.ava.helper",
    "productName": "AVA Helper",
    "directories": {
      "output": "dist/installers",
      "buildResources": "build"
    },
    "files": [
      "dist/main.cjs",
      "assets/**"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "identity": null
    },
    "win": {
      "target": "nsis"
    }
  }
}
