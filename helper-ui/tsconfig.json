{
  // Ärver repots strikta regler (ADR 0005 §Språk): Bun-globaler för test,
  // egen paths-bas (delar protokoll-/adapter-typer med webbappen via @/), egen
  // include. Täcker både Electron-skalet (src/main.ts) och den in-process-körda
  // motorn (src/engine/, ADR 0030); `electron` typas via dev-dependency.
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["bun-types"],
    "paths": {
      "@/*": ["../src/*"]
    },
    "noEmit": true
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "make-icons.ts"],
  "exclude": ["node_modules"]
}
