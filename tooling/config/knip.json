{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/app/**/page.tsx",
    "src/app/**/layout.tsx",
    "src/lib/server/routers/_app.ts",
    "tooling/scripts/*.ts",
    "test/e2e/*.spec.ts",
    "test/unit/**/*.test.{ts,tsx}",
    "test/scripts/*.test.ts",
    "next.config.{ts,js,mjs}",
    "postcss.config.{js,mjs}"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "tooling/scripts/**/*.ts"
  ],
  "ignore": [
    "tooling/scripts/oauth-proxy/**"
  ],
  "ignoreDependencies": [
    "tailwindcss"
  ],
  "ignoreBinaries": [
    "dot"
  ],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "unlisted": "error",
    "unresolved": "error",
    "binaries": "error",
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "enumMembers": "warn",
    "duplicates": "warn"
  }
}
