{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/app/**/page.tsx",
    "src/app/**/layout.tsx",
    "src/lib/server/routers/_app.ts",
    "tooling/scripts/*.ts",
    "test/e2e/*.spec.ts",
    "test/unit/**/*.test.{ts,tsx}",
    "test/scripts/*.test.ts",
    "next.config.{ts,js,mjs}",
    "postcss.config.{js,mjs}",

    "src/lib/shared/schemas/*.ts",
    "src/lib/server/data-store/IDataStore.ts",
    "src/lib/server/ports.ts",
    "src/lib/server/events/schema.ts",
    "src/lib/server/rules/schema.ts",
    "src/lib/server/trpc.ts",
    "src/lib/server/trpc-core.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "tooling/scripts/**/*.ts"
  ],
  "ignore": [
    "tooling/scripts/oauth-proxy/**"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "tailwindcss"
  ],
  "ignoreBinaries": [
    "dot",
    "tooling/scripts/generate-demo-manifest.ts"
  ],
  "commitlint": {
    "config": ["tooling/config/commitlint.config.mjs"]
  },
  "rules": {
    "files": "error",
    "dependencies": "error",
    "unlisted": "error",
    "unresolved": "error",
    "binaries": "error",
    "exports": "error",
    "types": "error",
    "nsExports": "warn",
    "nsTypes": "warn",
    "enumMembers": "warn",
    "duplicates": "warn"
  }
}
