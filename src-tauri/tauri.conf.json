{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AVA",
  "version": "0.1.0",
  "identifier": "se.ava.crm",
  "build": {
    "beforeDevCommand": "yarn dev:next",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "bash scripts/build-tauri.sh",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "AVA",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Business",
    "shortDescription": "Local-first CRM för advokatbyråer",
    "longDescription": "AVA är ett egendrivet CRM för svenska advokatbyråer. All klientdata lagras lokalt på din maskin; sync sker via git mot en byrå-egen server."
  }
}
