{
  "name": "ava",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,webdav,cors -c blue,magenta,cyan \"next dev\" \"tsx watch tooling/scripts/webdav-server.ts\" \"yarn dev:cors\"",
    "dev:next": "next dev",
    "dev:webdav": "tsx watch tooling/scripts/webdav-server.ts",
    "dev:cors": "cors-proxy start -p 9999",
    "dev:demo": "concurrently -n next,cors -c blue,cyan \"next dev\" \"yarn dev:cors\"",
    "build": "next build",
    "build:demo": "DEMO_BASE_PATH=/ava bash tooling/scripts/build-demo.sh",
    "build:demo-repo": "tsx tooling/scripts/build-demo-repo.ts",
    "build:tauri": "bash tooling/scripts/build-tauri.sh",
    "start": "next start",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tier3:up": "docker compose -f tooling/docker/docker-compose.yml up -d --build",
    "tier3:down": "docker compose -f tooling/docker/docker-compose.yml down",
    "tier3:restart": "docker compose -f tooling/docker/docker-compose.yml restart web",
    "tier3:logs": "docker compose -f tooling/docker/docker-compose.yml logs -f",
    "tier2:up": "docker compose -f tooling/docker/docker-compose.dev.yml up -d",
    "tier2:down": "docker compose -f tooling/docker/docker-compose.dev.yml down",
    "ava": "tsx tooling/scripts/ava-cli.ts",
    "bootstrap": "bash tooling/scripts/bootstrap-local-first.sh",
    "schema:sqlite": "tsx tooling/scripts/generate-sqlite-schema.ts",
    "migrate:pg-to-git": "tsx tooling/scripts/migrate-pg-to-git.ts",
    "seed:rules": "tsx tooling/scripts/seed-rules.ts",
    "seed:scenarios": "tsx tooling/scripts/seed-scenario-data.ts",
    "lint": "eslint --config tooling/config/eslint.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest --config tooling/config/vitest.config.ts",
    "test:run": "vitest run --config tooling/config/vitest.config.ts",
    "test:ui": "vitest --config tooling/config/vitest.config.ts --ui",
    "test:cov": "vitest run --config tooling/config/vitest.config.ts --coverage",
    "test:fast": "vitest run --config tooling/config/vitest.config.ts --exclude '**/test/scripts/**' --exclude '**/test/e2e/**'",
    "e2e": "playwright test --config tooling/config/playwright.config.ts",
    "e2e:ui": "playwright test --config tooling/config/playwright.config.ts --ui",
    "e2e:install": "playwright install --with-deps chromium",
    "round-trip": "playwright test --config tooling/config/playwright.round-trip.config.ts",
    "scenarios": "bash tooling/scripts/test-scenarios.sh",
    "scenarios:ui": "playwright test --config tooling/config/playwright.scenarios.config.ts --ui",
    "smoke:tier3": "bash tooling/scripts/test-tier3-smoke.sh",
    "test:full": "bash tooling/scripts/test-full.sh",
    "test:all": "bash tooling/scripts/test-all.sh",
    "duplicates": "jscpd --config tooling/config/jscpd.json src tooling/scripts/webdav-server.ts",
    "deps:check": "depcruise --config tooling/config/dependency-cruiser.cjs --output-type err src tooling/scripts/webdav-server.ts",
    "deps:graph": "depcruise --config tooling/config/dependency-cruiser.cjs --output-type dot src tooling/scripts/webdav-server.ts | dot -Tsvg > reports/dependency-graph.svg",
    "deps:archi": "depcruise --config tooling/config/dependency-cruiser.cjs --output-type archi src tooling/scripts/webdav-server.ts | dot -Tsvg > reports/architecture.svg",
    "knip": "knip --config tooling/config/knip.json",
    "knip:report": "knip --config tooling/config/knip.json --no-exit-code",
    "quality": "npm run typecheck && npm run lint && npm run test:cov && npm run duplicates && npm run deps:check && npm run knip:report",
    "quality:fast": "npm run typecheck && npm run lint && npm run test:fast",
    "quality:report": "mkdir -p reports && npm run test:cov && npm run duplicates && npm run deps:check || true",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --config tooling/config/eslint.config.mjs --fix",
      "bash -c 'tsc --noEmit'"
    ]
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.83",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tanstack/react-query": "^5.99.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@testing-library/dom": "^10.4.1",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "handlebars": "^4.7.9",
    "html-to-docx": "^1.8.0",
    "isomorphic-git": "^1.38.1",
    "json-logic-js": "^2.0.5",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "next": "16.2.3",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "pdfjs-dist": "^5.7.284",
    "pg": "^8.20.0",
    "puppeteer": "^24.41.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "vite": "^8.0.11",
    "yjs": "^13.6.30",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@isomorphic-git/cors-proxy": "^3.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/json-logic-js": "^2.0.8",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "husky": "^9.1.7",
    "jscpd": "^4.0.9",
    "jsdom": "^29.1.1",
    "knip": "^6.12.1",
    "lint-staged": "^16.4.0",
    "pdf-lib": "^1.17.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-plugin-tsconfig-paths": "^1.4.1",
    "vitest": "^4.1.4"
  }
}
